# Python-generated files
__pycache__/
*.py[oc]
*.swp
.mplconfig/
build/
dist/
wheels/
*.egg-info
.ruff_cache
.python-version

# Virtual environments
.venv

# Plots (transient run outputs). Curated figures referenced by the README live in
# plots/ and are tracked via the negations below; everything else stays ignored.
*.jpg
*.jpeg
*.png
*.pdf
!plots/*.jpg
!plots/*.png

# Data
*.dat
# but track the small ASCII 1D atmospheric model so the tools run out-of-the-box
!models/*.dat
diff_binning
*.nc
*.tar
*.zst
*.npy

# Debug dumps from sort_weighted_opacity_per_tau_bin
debug_tau_bin_*.json

# Q_rad explorer server runtime (make start/stop)
.webapp.pid
webapp.log
